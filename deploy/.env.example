# Copy to deploy/.env (git-ignored). For the PRODUCTION stack
# (deploy/compose.prod.yaml) run `make gen-secrets` to create deploy/.env with the
# secrets below filled in. The DEV stack (docker-compose.yml) only needs APP_BIND.

# Where the gateway publishes on the HOST. Default is loopback only.
# Never bind to 0.0.0.0 on a host with a public IP — the data-plane is the
# only authenticated surface; the datastores are not. To reach a remote box,
# prefer an SSH tunnel or `kubectl port-forward` over publishing on a NIC.
# (With the tls profile, Caddy is the public entry — keep APP_BIND on loopback.)
#
#   APP_BIND=127.0.0.1:8080      # default: localhost only
#   APP_BIND=10.0.0.2:8088       # publish on a specific private LAN interface
APP_BIND=127.0.0.1:8080

# --- Required for the production stack (ENV=prod). `make gen-secrets` fills these. ---
# 32-byte AES key (base64) that seals provider credentials. KEEP IT — rotating it
# strands everything sealed with the old key.
#   openssl rand -base64 32
AIRLLM_MASTER_KEY=
# Permanent admin login (survives restarts; change it in the console after first login).
#   openssl rand -base64 24
AIRLLM_ADMIN_USERNAME=admin
AIRLLM_ADMIN_PASSWORD=
# Postgres password. Use hex (URL-safe — it goes inside DATABASE_URL).
#   openssl rand -hex 24
POSTGRES_PASSWORD=

# --- TLS profile (docker compose -f deploy/compose.prod.yaml --profile tls up -d) ---
# A real domain pointed at this host, plus an email for Let's Encrypt. Open ports 80/443.
DOMAIN=airllm.example.com
ACME_EMAIL=ops@example.com

# --- Optional: OIDC SSO instead of local auth ---
# AUTH_MODE=oidc
# OIDC_ISSUER=https://issuer.example.com
# OIDC_CLIENT_ID=airllm
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=https://airllm.example.com/auth/callback
# OIDC_ROLES_CLAIM=roles
# OIDC_SCOPES=openid profile email   # SPACE-delimited
# OIDC_ROLE_MAP=idp-admins:airllm_admin,idp-users:airllm_user   # comma-delimited

# AIRLLM_SESSION_KEY is optional — it derives from AIRLLM_MASTER_KEY (HKDF) when unset.
# Set it (base64 32 bytes) only if you want to rotate session keys independently.
# AIRLLM_SESSION_KEY=
