# Copy to deploy/.env (git-ignored) to override docker-compose defaults.
#
# Where the gateway publishes on the HOST. Default is loopback only.
# Never bind to 0.0.0.0 on a host with a public IP — the data-plane is the
# only authenticated surface; the datastores are not. To reach a remote box,
# prefer an SSH tunnel or `kubectl port-forward` over publishing on a NIC.
#
#   APP_BIND=127.0.0.1:8080      # default: localhost only
#   APP_BIND=10.0.0.2:8088       # publish on a specific private LAN interface
APP_BIND=127.0.0.1:8080
