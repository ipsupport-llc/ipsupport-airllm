{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "AirLLM Helm values",
  "type": "object",
  "required": ["image", "existingSecret", "config", "app", "dlpBert", "metrics"],
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "existingSecret": { "type": "string" },
    "imagePullSecrets": { "type": "array" },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "env": { "type": "string" },
        "httpAddr": { "type": "string" },
        "authMode": { "type": "string", "enum": ["local", "oidc"] },
        "adminUsername": { "type": "string" },
        "captureBlobDir": { "type": "string" }
      }
    },
    "app": {
      "type": "object",
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 0 },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
            "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
          }
        },
        "ingress": {
          "type": "object",
          "properties": { "enabled": { "type": "boolean" } }
        }
      }
    },
    "dlpBert": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "modelMaxConcurrency": { "type": "integer", "minimum": 0 },
        "service": {
          "type": "object",
          "properties": { "headless": { "type": "boolean" }, "port": { "type": "integer" } }
        },
        "autoscaling": {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "enum": ["hpa", "keda", "none"] },
            "minReplicaCount": { "type": "integer", "minimum": 0 },
            "maxReplicaCount": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "serviceMonitor": {
          "type": "object",
          "properties": { "enabled": { "type": "boolean" } }
        },
        "dashboards": {
          "type": "object",
          "properties": { "enabled": { "type": "boolean" } }
        }
      }
    }
  }
}
